# CoExistree 环境变量配置示例
# 复制此文件为 .env 并填写实际值

# ============================================
# 必需配置
# ============================================

# OpenAI API Key（必需）
# 获取地址：https://platform.openai.com/api-keys
LLM_API_KEY=

# 管理员初始密码（必需）
# 系统启动时会自动创建 admin 用户，使用此密码
# 要求：至少8位，包含大小写字母和数字
ADMIN_INITIAL_PASSWORD=

# JWT 签名密钥（必需）
# 用于签发和验证 JWT Token，必须至少32位字符
# 生产环境请使用强随机字符串
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars

# ============================================
# 可选配置
# ============================================

# OpenAI API Base URL（可选）
# 默认：https://api.openai.com/v1
# 如果使用代理或第三方兼容服务，请修改此项
# LLM_BASE_URL=https://api.openai.com/v1

# LLM 模型选择（可选，默认：gpt-4o-mini）
# 可选值：gpt-4o, gpt-4o-mini, gpt-4-turbo 等
LLM_MODEL=gpt-4o-mini

# JWT Token 过期时间（毫秒），默认24小时
# JWT_EXPIRATION=86400000

# JVM 参数
JAVA_OPTS=-Xms512m -Xmx2g -XX:+UseG1GC

# 数据存储路径（H2 数据库和文件存储位置）
STORAGE_PATH=./data
