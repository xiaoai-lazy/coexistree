# CoExistree 环境变量配置示例
# 复制此文件为 .env 并填写实际值

# ============================================
# 必需配置
# ============================================

# 字节跳动 Ark API Key（必需）
# 获取地址：https://console.volcengine.com/ark/
LLM_API_KEY=

# ============================================
# 可选配置
# ============================================

# LLM 模型选择
LLM_MODEL=doubao-seed-2-0-pro-260215

# JVM 参数
JAVA_OPTS=-Xms512m -Xmx2g -XX:+UseG1GC

# 数据存储路径（H2 数据库和文件存储位置）
STORAGE_PATH=./data
